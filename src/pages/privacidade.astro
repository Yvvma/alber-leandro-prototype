---

import Layout from '../layouts/Layout.astro';
import Privacidade from '../components/Privacidade'





---

<Layout title="Privacidade">
	<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-element-bundle.min.js"></script>
	<div class='w-screen bg-gradient-to-br from-black  via-gray-800 to-gray-900 opacity-100'>
		  
		<div class="flex flex-row h-screen bg-cover bg-center relative" style="background-image: url('/photos/alber-03.webp')"> 
			
			<div class="absolute inset-0 bg-black/40 z-1"></div>
			<div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-black/100 to-transparent"></div>
		</div>

		<Privacidade client:load/>
		
			
	</div>
	
</Layout>
