---
import '../styles/global.css'
import AppWrapper from '../components/UI/AppWrapper';
---
<!-- Website made by industriebrasil.com.br -->
<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" sizes='32x32' href="/logos/favicon-alber-leandro-02.png" />
		<meta name="generator" content='Website oficial de Malcolm VL – rapper e ator brasileiro, indicado ao Emmy duas vezes. Explore sua música, atuação, prêmios, lançamentos e trajetória artística' />
		<title>{Astro.props.title}</title>

		
		<!-- Critical image preloads with fetchpriority -->
		<link rel="preload" href="/photos/01.jpg" as="image" fetchpriority="high" />
		<link rel="preload" as="video" href="/shows/cena-malcolm-video.mp4" type="video/mp4" />
		<link rel="preload" as="video" href="/videos/grunge-bg.mp4" type="video/mp4" />
		<link rel="preload" href="/logos/vl-logo-v2.gif" as="image" fetchpriority="high" />
		<link rel="preload" as="video" href="/series/tic-tac-malcolm-vl.mp4" type="video/mp4" />
		<link rel="preload" as="video" href="/publicidade/mc-donalds-malcolm-vl.mp4" type="video/mp4" />
		<link rel="preload" as="video" href="/songs/pineapple-malcolm.mp4" type="video/mp4" />
				
		<!-- Non-critical resources with lower priority -->
		
		<!-- Video preloading - only metadata for faster initial load -->
		<link rel="preload" href="/videos/grunge-bg.mp4" as="video" type="video/mp4" crossorigin="anonymous">
		
		
	</head>
	<body class="bg=[#131313]">
		<AppWrapper client:load>
			<slot />
		</AppWrapper>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
